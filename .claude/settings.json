{
  "mcpServers": {
    "set-mcp": {
      "command": "C:/Users/Pizza/AppData/Local/Programs/Python/Python312/Scripts/uvx.exe",
      "args": ["set-mcp"],
      "description": "Thai SET financial statements — Income, Balance Sheet, Cash Flow via SETSMART"
    },
    "tradingview": {
      "command": "C:/Program Files/nodejs/node.exe",
      "args": ["C:/Users/Pizza/OneDrive/Desktop/tradingview-mcp/src/server.js"],
      "description": "TradingView Desktop bridge — price, volume, MA, indicators via Chrome DevTools Protocol. Requires TradingView Desktop running with --remote-debugging-port=9222"
    },
    "notebooklm": {
      "command": "python",
      "args": ["C:/Users/Pizza/OneDrive/Desktop/AlphaAbsolute/scripts/notebooklm_mcp.py"],
      "description": "AlphaAbsolute NotebookLM knowledge base — 5 notebooks"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "description": "Browser automation — click, fill forms, screenshot, test web. No API key needed."
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "description": "Chrome DevTools Protocol — inspect DOM, network requests, console errors, performance. Requires Chrome running."
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "YOUR_PERPLEXITY_API_KEY_HERE"
      },
      "description": "Perplexity AI — live web search, deep research, reasoning. Get API key at: https://www.perplexity.ai/settings/api"
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY_HERE"
      },
      "description": "Firecrawl — web scraping, crawl sites, extract structured data. Get API key at: https://www.firecrawl.dev"
    },
    "glif": {
      "command": "npx",
      "args": ["-y", "@glifxyz/glif-mcp-server"],
      "env": {
        "GLIF_API_TOKEN": "YOUR_GLIF_API_TOKEN_HERE"
      },
      "description": "Glif — generate images, video, audio, voice cloning via AI workflows. Get token at: https://glif.app/settings"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/session_start.py 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/post_runner_log.py 2>/dev/null || true",
            "timeout": 8000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/hooks/session_stop.py 2>/dev/null || true",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python scripts/*.py)",
      "Bash(uvx set-mcp)",
      "Bash(uvx set-mcp *)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Bash(pip install *)",
      "Bash(python3 -m pip install requests pandas openpyxl anthropic python-pptx)",
      "Bash(python -c '*)",
      "Bash(python scripts/daily_report.py)",
      "Bash(python -m playwright install chromium 2>&1)",
      "Bash(python -m notebooklm login)",
      "Bash(node \"C:/Users/Pizza/OneDrive/Desktop/tradingview-mcp/src/server.js\" --version)",
      "Bash(npm --version)",
      "mcp__Claude_in_Chrome__tabs_context_mcp",
      "mcp__Claude_in_Chrome__javascript_tool",
      "mcp__Claude_in_Chrome__get_page_text",
      "mcp__Claude_in_Chrome__navigate",
      "mcp__Claude_in_Chrome__read_page",
      "mcp__2354805f-598d-4643-b3df-6e0154420a0a__find_companies",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:savvytrader.com)",
      "WebFetch(domain:www.youtube.com)",
      "WebFetch(domain:www.investors.com)",
      "WebFetch(domain:www.pragcap.com)",
      "WebFetch(domain:www.scribd.com)",
      "WebFetch(domain:ibdstock.com)",
      "WebFetch(domain:www.zyo71.com)",
      "WebFetch(domain:www.lucid-trader.com)",
      "WebFetch(domain:www.finermarketpoints.com)",
      "WebFetch(domain:www.chartmill.com)"
    ]
  }
}
