# AlphaAbsolute — Environment Variables Template
# Copy this file to .env and fill in your keys
# .env is in .gitignore — never commit it

# ─── FRED (US Macro data — FREE) ─────────────────────────────────────────────
# Get free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# ─── Finnhub (Market data — FREE tier) ───────────────────────────────────────
# Get free key: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# ─── Groq (FREE — Primary LLM, 14,400 req/day) ───────────────────────────────
# Get free key: https://console.groq.com (sign up, no CC needed)
# Free: 14,400 req/day, 30 RPM — llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_key_here

# ─── Google Gemini 2.5 Flash (FREE — Secondary LLM, 20 req/day) ──────────────
# Get free key: https://aistudio.google.com/app/apikey (Google account, no CC)
GEMINI_API_KEY=your_gemini_key_here

# ─── Anthropic LLM (paid backup — optional) ──────────────────────────────────
# Get key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Create bot: https://t.me/BotFather -> /newbot
# Get chat ID: message your bot then GET https://api.telegram.org/bot{token}/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─── Obsidian Local REST API ──────────────────────────────────────────────────
# 1. Install Obsidian: https://obsidian.md
# 2. Open vault: obsidian-vault/AlphaAbsolute/
# 3. Install plugin: Settings -> Community Plugins -> Local REST API
# 4. Copy API key from plugin settings
# Port 27125 avoids conflict with default port 27124 (pre-configured in vault)
OBSIDIAN_API_KEY=your_obsidian_api_key_here
OBSIDIAN_URL=https://127.0.0.1:27125
